# ── Microsoft Outlook / Azure ──
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_AUTHORITY=https://login.microsoftonline.com/<tenant_id>
AZURE_SCOPES=https://graph.microsoft.com/.default
GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0
EMAIL_ADDRESS=info@lemartinhotel.com

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.3

# ── Thais PMS ──
THAIS_API_URL=https://demo.thais-hotel.com
THAIS_API_USER=
THAIS_API_PASSWORD=
THAIS_USER_AGENT=VisionIA-LeMartin/1.0
THAIS_HOTEL_ID=

# ── Supabase ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Hotel ──
HOTEL_NAME=Le Martin Boutique Hotel
HOTEL_LOCATION=Saint-Martin (Antilles françaises)

# ── Application ──
APP_MODE=draft
POLL_INTERVAL=60
DEFAULT_LANGUAGE=fr
EMAIL_SIGNATURE_NAME=Marion
EMAIL_SIGNATURE_ROLE=Réception
MAX_EMAILS_PER_CYCLE=10
LOG_LEVEL=info

# ── Escalation ──
ESCALATION_CONFIDENCE_THRESHOLD=0.7
ESCALATION_EMAIL=emmanuel@lemartinhotel.com

# ── Notifications ──
NOTIFY_EMAIL=emmanuel@lemartinhotel.com
DAILY_SUMMARY_HOUR=18
DAILY_SUMMARY_TIMEZONE=America/Guadeloupe

# ── Environment ──
ENVIRONMENT=production
